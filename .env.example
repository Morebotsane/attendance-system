# Environment Configuration
# Copy this file to .env and update with your values

# Application
PROJECT_NAME="Hospital Attendance System"
VERSION="1.0.0"
ENVIRONMENT="development"  # development, staging, production

# Security
SECRET_KEY="your-super-secret-key-change-in-production-min-32-chars"
QR_ENCRYPTION_KEY="your-fernet-key-44-chars-base64-encoded"  # Generate with: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/attendance_db"
DB_ECHO="false"

# Redis
REDIS_URL="redis://localhost:6379/0"
REDIS_CACHE_TTL=3600

# Celery
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# CORS - Add your frontend URLs
ALLOWED_ORIGINS='["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000"]'

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Photo Storage
PHOTO_STORAGE_TYPE="local"  # 'local' or 's3'
PHOTO_MAX_SIZE_MB=5
PHOTO_ALLOWED_EXTENSIONS='[".jpg",".jpeg",".png"]'

# S3 Settings (if using cloud storage)
S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

# Geofencing
DEFAULT_GEOFENCE_RADIUS_METERS=100
GEOFENCE_ACCURACY_REQUIRED_METERS=50

# Attendance Rules
CHECK_IN_GRACE_PERIOD_MINUTES=15
LATE_THRESHOLD_MINUTES=15
DUPLICATE_CHECK_IN_PREVENTION_HOURS=1

# Email Settings (Optional)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM=""

# Feature Flags
ENABLE_PHOTO_VERIFICATION="true"
ENABLE_FACE_MATCHING="false"
ENABLE_SMS_NOTIFICATIONS="false"
ENABLE_EMAIL_NOTIFICATIONS="false"

# Logging
LOG_LEVEL="INFO"
LOG_FILE="logs/app.log"

# SMS Notifications
# Africa's Talking (Primary - FREE Sandbox!)
# Sign up: https://account.africastalking.com/auth/register
AFRICAS_TALKING_USERNAME="sandbox"
AFRICAS_TALKING_API_KEY=""

# Twilio SMS (Backup - Optional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Email Notifications
# For Gmail: Use App Password (not regular password)
# Generate at: https://myaccount.google.com/apppasswords
FROM_EMAIL=""
FROM_NAME="Hospital Attendance System"